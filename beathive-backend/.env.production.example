# ─── Arsonus — Production Environment ────────────────────
# Copy this file to .env and fill in your production values.
# NEVER commit .env to version control!

# ── App ─────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
FRONTEND_URL=https://arsonus.com

# ── Database (PostgreSQL) ───────────────────────────────
# For Docker Compose, use: postgresql://arsonus:YOUR_DB_PASSWORD@postgres:5432/arsonus_db
DATABASE_URL=postgresql://arsonus:CHANGE_ME@localhost:5432/arsonus_db

# ── Redis ───────────────────────────────────────────────
# For Docker Compose, use: redis://redis:6379
REDIS_URL=redis://localhost:6379

# ── JWT Secrets ─────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
JWT_REFRESH_EXPIRES_IN=30d
JWT_RESET_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL

# ── Google OAuth ────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_production_client_id
GOOGLE_CLIENT_SECRET=your_production_client_secret
GOOGLE_CALLBACK_URL=https://api.arsonus.com/api/v1/auth/google/callback

# ── Midtrans Payment ───────────────────────────────────
# Get from: https://dashboard.midtrans.com
MIDTRANS_IS_PRODUCTION=true
MIDTRANS_SERVER_KEY=Mid-server-CHANGE_ME
MIDTRANS_CLIENT_KEY=Mid-client-CHANGE_ME
MIDTRANS_MERCHANT_ID=CHANGE_ME

# ── Email (SMTP) ───────────────────────────────────────
# Option 1: Generic SMTP (Gmail, SendGrid, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@arsonus.com

# Option 2: Mailgun (legacy, works if SMTP_HOST is empty)
# MAILGUN_API_KEY=key-CHANGE_ME
# MAILGUN_DOMAIN=mg.arsonus.com

# ── Storage ─────────────────────────────────────────────
# Local storage only (no AWS S3)
USE_LOCAL_STORAGE=true

# ── Docker Compose Overrides ───────────────────────────
# Only needed when using docker-compose.yml
POSTGRES_DB=arsonus_db
POSTGRES_USER=arsonus
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
BACKEND_PORT=3000
FRONTEND_PORT=3001

# ── Frontend Build Args ────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.arsonus.com/api/v1
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=Mid-client-CHANGE_ME
NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION=true
